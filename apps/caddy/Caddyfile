# Job Search Pal — HTTPS reverse proxy for the web app.
#
# Listens on :443, terminates TLS using a self-signed cert generated
# at container startup by entrypoint.sh (stored in the caddy_data
# volume). SAN entries cover localhost / *.local / *.lan / the
# CADDY_HOSTNAME env var. Add your server's public IP / hostname to
# CADDY_EXTRA_SANS in .env (e.g. `IP:203.0.113.5,DNS:my.public.com`)
# to get a clean lock without warnings.
#
# Next.js handles /api/* and /health/* via its own rewrites
# pointing at api:8000, so this proxy only needs to know about the
# web container.
#
# To use a real domain + Let's Encrypt instead of self-signed:
#   1. Set CADDY_HOSTNAME in .env to your public hostname
#   2. Replace the `tls /data/...` line with `tls {$ADMIN_EMAIL}`
#   3. Make sure ports 80 + 443 are reachable from the internet
#   4. Delete the volumes/jsp-tls dir to drop the self-signed cert

{
	email {$ADMIN_EMAIL:admin@local}
	admin off
	# Bring our own TLS cert via the entrypoint script — disable
	# Caddy's automatic HTTPS so it doesn't try to provision certs
	# from LE / internal CA on every hostname it sees.
	auto_https off
}

https://:443 {
	bind 0.0.0.0
	tls /data/jsp-tls/cert.pem /data/jsp-tls/key.pem

	# Larger upload cap for resume / cover-letter ingest.
	request_body {
		max_size 50MB
	}

	reverse_proxy web:3000 {
		# Keep websocket + SSE upgrades transparent for the
		# Companion's queue stream.
		flush_interval -1
	}
}
