# Job Search Pal environment configuration
# Copy to .env and fill in values. setup.sh will generate this for you.

# ---- Core ----
APP_NAME=JobSearchPal
APP_ENV=development
APP_PORT=8080
API_PORT=8000
WEB_PORT=4000

# ---- Database ----
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=jobsearchpal
MYSQL_USER=jsp
MYSQL_PASSWORD=change-me-to-a-strong-password
MYSQL_ROOT_PASSWORD=change-me-to-another-strong-password

# ---- Security ----
# Long random secret used for signing sessions and JWTs
SESSION_SECRET=change-me-to-a-long-random-secret
# Master secret used to derive the key that encrypts ApiCredential rows
MASTER_SECRET=change-me-to-another-long-random-secret

# ---- LLM access ----
# Two options (you only need one):
#
#   1) Recommended: Claude Code CLI with your existing login.
#      Run `claude login` on the host once, then point CLAUDE_HOME at the
#      resulting config directory. The API container bind-mounts it as
#      /root/.claude so subprocess calls reuse your OAuth session.
#      Uses your Claude subscription (Pro / Max / Team) — no per-token billing.
#
#   2) Fallback: pay-per-token Anthropic API key.
#      Set ANTHROPIC_API_KEY below. Leave CLAUDE_HOME pointed at the
#      placeholder (the default) so nothing conflicts.
#
# Path on the host to your Claude Code config directory. On Linux/macOS/Git-Bash
# this is typically ~/.claude. Docker Compose does not expand ~, so use an
# absolute path — setup.sh will fill this in.
CLAUDE_HOME=./.claude-placeholder

# Optional — only needed if you are NOT using Claude Code CLI auth.
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# Claude Code CLI binary name and skill-discovery path inside the container.
CLAUDE_CODE_BIN=claude
SKILLS_DIR=/app/skills

# ---- Frontend ----
# Leave NEXT_PUBLIC_API_URL empty to let the browser derive it from window.location
# (required for LAN access from other devices). Set only if you're fronting with
# a reverse proxy or hosting the API on a fixed different hostname.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_PORT=8000
