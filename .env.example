# Job Search Pal environment configuration
# Copy to .env and fill in values. setup.sh will generate this for you.

# ---- Core ----
APP_NAME=JobSearchPal
APP_ENV=development
APP_PORT=8080
API_PORT=8000
WEB_PORT=4000

# ---- Database ----
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=jobsearchpal
MYSQL_USER=jsp
MYSQL_PASSWORD=change-me-to-a-strong-password
MYSQL_ROOT_PASSWORD=change-me-to-another-strong-password

# ---- Security ----
# Long random secret used for signing sessions and JWTs
SESSION_SECRET=change-me-to-a-long-random-secret
# Master secret used to derive the key that encrypts ApiCredential rows
MASTER_SECRET=change-me-to-another-long-random-secret

# ---- LLM access ----
# The API container ships with the Claude Code CLI installed and stores its
# config in an isolated named volume (claude_config). After the stack is up,
# complete the standard OAuth login once with:
#
#     docker compose exec -it api claude login
#
# That persists credentials inside the container's own config volume. The
# container does NOT touch your personal ~/.claude on the host.
#
# If you'd rather use pay-per-token API access, set ANTHROPIC_API_KEY below
# and skip the login step. Either path works.

ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-7

# Claude Code CLI binary name and skill-discovery path inside the container.
CLAUDE_CODE_BIN=claude
SKILLS_DIR=/app/skills

# ---- Frontend ----
# Leave NEXT_PUBLIC_API_URL empty to let the browser derive it from window.location
# (required for LAN access from other devices). Set only if you're fronting with
# a reverse proxy or hosting the API on a fixed different hostname.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_PORT=8000

# ---- CORS ----
# By default the API accepts requests from loopback, RFC1918 LAN ranges, and
# *.local mDNS names on any port. If you host on a public IP / DNS name or
# reverse-proxy host that doesn't match those patterns, add origins here.
# Example: EXTRA_CORS_ORIGINS=http://my-server.corp:4000,http://203.0.113.5:4000
EXTRA_CORS_ORIGINS=
# Set true to bypass the allowlist entirely (wildcard origin + credentials).
# Dev only — any site the user visits could issue requests with their cookie.
ALLOW_ALL_ORIGINS=false

# ---- Streamed browser (R10) ----
# The chromium service runs Chromium + KasmVNC inside its own container.
# CHROMIUM_PORT is the host-side port the KasmVNC web UI is mapped to —
# the /browser page iframes it directly. CHROMIUM_VNC_PASSWORD gates
# initial access to the VNC stream.
CHROMIUM_PORT=6901
CHROMIUM_VNC_PASSWORD=jobsearchpal
# Optional override the frontend uses when it can't derive the host from
# window.location (e.g., behind a reverse proxy). Set to the URL the
# user's browser can reach at the chromium service.
NEXT_PUBLIC_CHROMIUM_URL=
NEXT_PUBLIC_CHROMIUM_PORT=6901
# Timezone passed to the chromium container so logs / UI render with
# your local time.
TZ=America/New_York

# ---- HTTPS reverse proxy (Caddy) ----
# Required for remote-host deployments — modern browsers refuse
# clipboard / WebRTC / secure-context APIs over plain HTTP to non-
# localhost origins, which breaks KasmVNC's streamed browser inside
# the /browser iframe. Caddy terminates TLS for the web app on
# HTTPS_WEB_PORT and the streamed Chromium on HTTPS_CHROMIUM_PORT.
# `tls internal` self-signs via Caddy's local CA — point your browser
# at https://<host>/ and trust the warning, or grab the root cert
# from `docker compose exec caddy cat /data/caddy/pki/authorities/local/root.crt`
# and install it in your client OS / browser to silence the warning
# permanently.
HTTPS_WEB_PORT=443
HTTPS_CHROMIUM_PORT=6443
ADMIN_EMAIL=admin@local
# When using HTTPS, point the frontend at the same hostname/port the
# user's browser will use to load the chromium iframe (e.g.
# https://my-server.corp:6443). Without this, the page tries to embed
# the iframe via the unencrypted CHROMIUM_PORT, which mixed-content
# rules will block under HTTPS.
# NEXT_PUBLIC_CHROMIUM_URL=https://my-server.corp:6443
